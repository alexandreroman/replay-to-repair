{
	admin off
	auto_https off
}

# Single entry point for the demo: static dashboard + API + Temporal Web UI
# reverse proxy.
:80 {
	encode gzip

	# API calls go to the backend container.
	handle /api/* {
		reverse_proxy {$BACKEND_UPSTREAM:backend:8080}
	}

	# Temporal Web UI, proxied under /temporal. The dev server runs with
	# --ui-public-path /temporal (see compose.yaml), so it serves its assets
	# under that prefix — forward the prefix instead of stripping it.
	handle /temporal* {
		reverse_proxy temporal:8233
	}

	# Everything else is the static frontend (SPA-style fallback).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
